{
	"schemaVersion": 1,
	"id": "serverutilities",
	"version": "${version}",
	"name": "Server Utilities Mod",
	"description": "Create persistent text holograms, interactive menus with container popups, and anvil text styling.",
	"icon": "assets/serverutilities/icon.png",
	"authors": [
		"URLTK"
	],
	"license": "MIT",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.serverutilities.ServerUtilitiesMod"
		],
		"client": [
			"com.serverutilities.client.ServerUtilitiesClient"
		]
	},
	"mixins": [
		"serverutilities.mixins.json",
		{
			"config": "serverutilities.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
